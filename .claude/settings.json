{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "scripts/hooks/remind-spec-update.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "scripts/hooks/block-no-verify.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/block-caddy-reload.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/block-bare-docker-pull.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/block-iterative-fixes.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/pre-commit-checks.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "scripts/hooks/check-migration-safety.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/block-prod-compose-build.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/warn-listener-wiring.sh",
            "type": "command"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "command": "scripts/hooks/check-migration-safety.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/check-ci-deploy-patterns.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/block-prod-compose-build.sh",
            "type": "command"
          },
          {
            "command": "scripts/hooks/warn-listener-wiring.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}