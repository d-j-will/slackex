{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "tenun_analytics_errors_count{category=\"js_error\"}",
          "legendFormat": "JS Error"
        },
        {
          "expr": "tenun_analytics_errors_count{category=\"server_error\"}",
          "legendFormat": "Server Error"
        },
        {
          "expr": "tenun_analytics_errors_count{category=\"oban_error\"}",
          "legendFormat": "Oban Error"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 10 }
        ]
      }
    },
    {
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "tenun_analytics_active_users_count",
          "legendFormat": "Active Users"
        }
      ]
    },
    {
      "title": "Top Pages",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "expr": "topk(20, tenun_analytics_page_views_count)",
          "legendFormat": "{{path}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "path": "Path",
              "Value": "Page Views"
            }
          }
        }
      ]
    },
    {
      "title": "Feature Usage",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "tenun_analytics_feature_usage_count",
          "legendFormat": "{{feature}}",
          "instant": true
        }
      ]
    },
    {
      "title": "Error Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "tenun_analytics_errors_count",
          "legendFormat": "{{category}}",
          "instant": true
        }
      ]
    },
    {
      "title": "Total Error Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(tenun_analytics_errors_count)",
          "legendFormat": "Total Errors"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["tenun", "analytics"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "refresh": "1m",
  "title": "Tenun \u2014 User Analytics",
  "uid": "tenun-analytics"
}
