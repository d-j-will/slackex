#!/bin/sh

# Enable Erlang distribution with fully-qualified node names
export RELEASE_DISTRIBUTION=name
export RELEASE_NODE=${RELEASE_NODE:-slackex@$(hostname -f)}

# Derive a release cookie from SECRET_KEY_BASE if not explicitly set
export RELEASE_COOKIE=${RELEASE_COOKIE:-$(echo "$SECRET_KEY_BASE" | sha256sum | cut -d' ' -f1)}
