#!/bin/sh

# Enable Erlang distribution with short node names (Docker Compose hostnames are short)
export RELEASE_DISTRIBUTION=sname
export RELEASE_NODE=${RELEASE_NODE:-slackex@$(hostname -s)}

# Derive a release cookie from SECRET_KEY_BASE if not explicitly set
export RELEASE_COOKIE=${RELEASE_COOKIE:-$(echo "$SECRET_KEY_BASE" | sha256sum | cut -d' ' -f1)}
