# This block is added to the host-level Caddy at /opt/caddy/Caddyfile.
# The host Caddy handles SSL via Cloudflare and proxies to the app containers
# on the shared "proxy" Docker network. Service names (app1, app2) resolve via
# Docker DNS aliases set by Compose on the external proxy network.
#
# Active health checks ensure Caddy stops routing to a downed node and fails
# over to the healthy one automatically (prevents 502 when a node is stopped).
#
# chat.davewil.dev {
#     reverse_proxy app1:4000 app2:4000 {
#         health_uri /health
#         health_interval 5s
#         health_timeout 3s
#         fail_duration 15s
#     }
# }
#
# The deploy script writes this block to /opt/caddy/slackex-proxy and imports it
# from the main Caddyfile automatically. No manual server changes needed.
