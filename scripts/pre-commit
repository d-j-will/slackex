#!/bin/sh
# Pre-commit hook: YAML lint + Elixir format check + fast test
#
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

# Fail if tracked files have unstaged changes — prevents committing
# a partial rename/refactor where some files were modified on disk
# but never staged. CI sees only what git tracks, not the working tree.
UNSTAGED=$(git diff --name-only -- '*.ex' '*.exs')
if [ -n "$UNSTAGED" ]; then
  echo ""
  echo "Pre-commit: ERROR — unstaged changes to tracked Elixir files:"
  echo "$UNSTAGED"
  echo ""
  echo "Stage them (git add) or stash them before committing."
  echo "This prevents CI failures from partial renames or refactors."
  exit 1
fi

STAGED_YML=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.ya?ml$')
STAGED_EX=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ex|exs)$')

# YAML validation (uses Ruby which ships with macOS)
if [ -n "$STAGED_YML" ]; then
  echo "Pre-commit: validating YAML..."
  for f in $STAGED_YML; do
    ruby -ryaml -e "YAML.safe_load(File.read('$f'), permitted_classes: [], permitted_symbols: [], aliases: true)" 2>&1
    if [ $? -ne 0 ]; then
      echo ""
      echo "YAML validation failed: $f"
      exit 1
    fi
  done
  echo "Pre-commit: YAML valid."
fi

# Elixir checks (only if .ex/.exs files staged)
if [ -n "$STAGED_EX" ]; then
  # `mix lint` = format --check-formatted + credo --strict + compile
  # --warnings-as-errors, all defined once in mix.exs and shared with CI's
  # quality job — so the flags can't drift between local and CI (the credo
  # --strict seam that let trailing whitespace pass locally but fail in CI).
  # MIX_ENV=test matches CI and lets `mix format` resolve dep formatter configs
  # (the migrations subdir imports ecto_sql) from _build/test.
  echo "Pre-commit: running lint (format + credo --strict + compile)..."
  MIX_ENV=test mix lint
  if [ $? -ne 0 ]; then
    echo ""
    echo "Lint failed. Run 'MIX_ENV=test mix lint' for details; if it is formatting,"
    echo "run 'MIX_ENV=test mix format' and re-stage."
    exit 1
  fi

  # MIX_ENV=test to match CI (its quality job runs everything under test). In
  # :dev, elixirc_paths excludes test/support, so dialyzer never analyses those
  # modules — a dev-env gate green-lights unmatched_returns in test helpers that
  # CI then catches under :test. Same local↔CI seam as the credo flag above.
  echo "Pre-commit: running Dialyzer..."
  MIX_ENV=test mix dialyzer
  if [ $? -ne 0 ]; then
    echo ""
    echo "Dialyzer check failed. Fix type issues before committing."
    exit 1
  fi

  echo "Pre-commit: running tests (--max-failures 1)..."
  mix test --max-failures 1
  if [ $? -ne 0 ]; then
    echo ""
    echo "Tests failed. Fix failures before committing."
    exit 1
  fi
fi

echo "Pre-commit: all checks passed."
