#!/usr/bin/env bash
#
# Caddy-docker-proxy cutover script
#
# Automates the migration from standalone Caddy to caddy-docker-proxy.
# Has a confirmation gate between test-port verification and production cutover.
#
# Usage: scripts/caddy-cutover <deploy-host>
# Example: scripts/caddy-cutover 100.x.y.z
#
# Prerequisites:
#   - SSH access to DEPLOY_HOST as root
#   - v0.5.71+ deployed (caddy infra files on server at /root/caddy/)
#   - CF_API_TOKEN value known (from existing /root/slackex/.env CADDY_CF_TOKEN)

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

DEPLOY_HOST="${1:?Usage: scripts/caddy-cutover <deploy-host>}"

info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[FAIL]${NC} $*"; }

ssh_cmd() { ssh -o StrictHostKeyChecking=accept-new "root@${DEPLOY_HOST}" "$@"; }

# --- Phase 1: Setup ---

info "Phase 1: Setup"

# Check SSH connectivity
info "Testing SSH connection..."
ssh_cmd "echo 'Connected to \$(hostname)'" || { error "Cannot SSH to ${DEPLOY_HOST}"; exit 1; }

# Check caddy infra files exist on server
info "Checking caddy infra files on server..."
ssh_cmd "test -f /root/caddy/Dockerfile && test -f /root/caddy/docker-compose.yml && test -f /root/caddy/Caddyfile" \
  || { error "Caddy infra files not found at /root/caddy/. Deploy v0.5.71+ first."; exit 1; }

# Check/create .env
if ssh_cmd "test -f /root/caddy/.env" 2>/dev/null; then
  info ".env already exists at /root/caddy/.env"
else
  warn ".env not found at /root/caddy/.env"
  echo ""
  echo "Enter the Cloudflare API token (same as CADDY_CF_TOKEN in /root/slackex/.env):"
  read -r -s CF_TOKEN
  echo ""
  ssh_cmd "echo 'CF_API_TOKEN=${CF_TOKEN}' > /root/caddy/.env && chmod 600 /root/caddy/.env"
  info "Created /root/caddy/.env"
fi

# Ensure proxy network exists
info "Ensuring proxy network exists..."
ssh_cmd "docker network inspect proxy >/dev/null 2>&1 || docker network create proxy"

# --- Phase 2: Build ---

info "Phase 2: Building custom caddy image..."
ssh_cmd "cd /root/caddy && docker compose build" || { error "Docker build failed"; exit 1; }
info "Build complete."

# --- Phase 3: Test ports ---

info "Phase 3: Starting on test ports (8080/8443)..."

# Temporarily set test ports
ssh_cmd "cd /root/caddy && sed -i 's/\"80:80\"/\"8080:80\"/' docker-compose.yml && sed -i 's/\"443:443\"/\"8443:443\"/' docker-compose.yml"
ssh_cmd "cd /root/caddy && docker compose up -d" || { error "Failed to start caddy-docker-proxy"; exit 1; }

info "Waiting 10s for caddy-docker-proxy to discover containers..."
sleep 10

# Verify routes
echo ""
info "=== Route Verification ==="
VERIFY_FAILED=0

for ROUTE in "chat.davewil.dev:/health" "grafana.davewil.dev:/" "davewil.dev:/"; do
  HOST="${ROUTE%%:*}"
  PATH="${ROUTE#*:}"
  echo -n "  ${HOST}${PATH} ... "

  RESULT=$(ssh_cmd "curl -sk -o /dev/null -w '%{http_code}' -H 'Host: ${HOST}' 'https://localhost:8443${PATH}'" 2>/dev/null) || RESULT="000"

  if [[ "$RESULT" =~ ^(200|302)$ ]]; then
    echo -e "${GREEN}OK${NC} (HTTP ${RESULT})"
  else
    echo -e "${RED}FAIL${NC} (HTTP ${RESULT})"
    VERIFY_FAILED=1
  fi
done

echo ""

if [ "$VERIFY_FAILED" = "1" ]; then
  error "Test-port verification failed. Inspect with:"
  echo "  ssh root@${DEPLOY_HOST} 'docker logs caddy-caddy-1'"
  echo "  ssh root@${DEPLOY_HOST} 'cd /root/caddy && docker compose down'"
  echo ""
  warn "Restoring docker-compose.yml to production ports before exiting..."
  ssh_cmd "cd /root/caddy && sed -i 's/\"8080:80\"/\"80:80\"/' docker-compose.yml && sed -i 's/\"8443:443\"/\"443:443\"/' docker-compose.yml && docker compose down"
  exit 1
fi

info "All routes verified on test ports."

# --- Phase 4: Cutover gate ---

echo ""
echo -e "${YELLOW}╔══════════════════════════════════════════════════════╗${NC}"
echo -e "${YELLOW}║  CUTOVER GATE: Ready to switch production traffic.  ║${NC}"
echo -e "${YELLOW}║  This will cause ~5s of downtime.                   ║${NC}"
echo -e "${YELLOW}║                                                     ║${NC}"
echo -e "${YELLOW}║  Type 'cutover' to proceed, anything else to abort. ║${NC}"
echo -e "${YELLOW}╚══════════════════════════════════════════════════════╝${NC}"
echo ""
read -r CONFIRM

if [ "$CONFIRM" != "cutover" ]; then
  warn "Aborted. Cleaning up test-port deployment..."
  ssh_cmd "cd /root/caddy && docker compose down && sed -i 's/\"8080:80\"/\"80:80\"/' docker-compose.yml && sed -i 's/\"8443:443\"/\"443:443\"/' docker-compose.yml"
  info "Test deployment stopped. Production unchanged."
  exit 0
fi

# --- Phase 5: Production cutover ---

info "Phase 5: Cutting over to production..."

# Stop old Caddy
info "Stopping old Caddy container..."
ssh_cmd "docker stop caddy 2>/dev/null || true"

# Stop test-port deployment, restore ports, start on production ports
info "Switching to production ports (80/443)..."
ssh_cmd "cd /root/caddy && docker compose down && sed -i 's/\"8080:80\"/\"80:80\"/' docker-compose.yml && sed -i 's/\"8443:443\"/\"443:443\"/' docker-compose.yml && docker compose up -d"

info "Waiting 10s for TLS certificate issuance..."
sleep 10

# --- Phase 6: Production verification ---

info "Phase 6: Production verification"
PROD_FAILED=0

for ROUTE in "chat.davewil.dev:/health" "grafana.davewil.dev:/" "davewil.dev:/"; do
  HOST="${ROUTE%%:*}"
  PATH="${ROUTE#*:}"
  echo -n "  https://${HOST}${PATH} ... "

  RESULT=$(curl -sf -o /dev/null -w '%{http_code}' "https://${HOST}${PATH}" 2>/dev/null) || RESULT="000"

  if [[ "$RESULT" =~ ^(200|302)$ ]]; then
    echo -e "${GREEN}OK${NC} (HTTP ${RESULT})"
  else
    echo -e "${RED}FAIL${NC} (HTTP ${RESULT})"
    PROD_FAILED=1
  fi
done

echo ""

if [ "$PROD_FAILED" = "1" ]; then
  error "Production verification failed!"
  echo ""
  echo "  To rollback: ssh root@${DEPLOY_HOST} 'cd /root/caddy && docker compose down && docker start caddy'"
  echo "  To debug:    ssh root@${DEPLOY_HOST} 'docker logs caddy-caddy-1'"
  exit 1
fi

# --- Phase 7: Cleanup ---

info "Phase 7: Cleaning up old Caddy..."
ssh_cmd "docker rm caddy 2>/dev/null || true"
ssh_cmd "rm -f /opt/caddy/Caddyfile 2>/dev/null || true"

echo ""
echo -e "${GREEN}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║  Cutover complete! caddy-docker-proxy is live.  ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════════════╝${NC}"
echo ""
info "Rollback (if needed later): ssh root@${DEPLOY_HOST} 'cd /root/caddy && docker compose down'"
