# Slackex Production Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# PostgreSQL password
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Phoenix secret key base (used for signing sessions/cookies)
# Generate with: openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=

# Cloak encryption key (AES-256-GCM, must be 32 bytes base64-encoded)
# Generate with: openssl rand -base64 32
CLOAK_KEY=

# Cloak HMAC secret (used for hashing encrypted fields)
# Generate with: openssl rand -base64 32
CLOAK_HMAC_SECRET=

# Guardian JWT signing key
# Generate with: openssl rand -base64 64 | tr -d '\n'
GUARDIAN_SECRET_KEY=
